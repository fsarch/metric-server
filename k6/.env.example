# k6 Load Test Configuration - Example File
# Copy this to .env and fill in your values

# Required: Access token for authentication
K6_ACCESS_TOKEN=your-bearer-token-here

# Optional: Metric ID for single measurement tests
# If not provided, random metric IDs will be used for bulk tests
K6_METRIC_ID=your-metric-id-here

# Optional: Base URL of the metric-server
# Default: http://localhost:3000
K6_BASE_URL=http://localhost:3000

# Optional: Number of virtual users
# Default: 10
K6_VUS=10

# Optional: Test duration
# Default: 60s (60 seconds)
# Examples: 30s, 2m, 5m, 10m
K6_DURATION=60s

# Optional: Number of measurements per bulk request
# Default: 100
K6_BULK_SIZE=100
